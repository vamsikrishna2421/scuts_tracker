# Scuts Tracker runtime config.
#
# Your Claude API key is entered INSIDE the app (Settings → Claude API) and stored
# securely in the device Keychain via expo-secure-store. Do NOT put an API key here,
# and never bundle one into a shared build.
#
# Optional: override the default model the agents start with (changeable in-app).
EXPO_PUBLIC_DEFAULT_MODEL=claude-opus-4-8
