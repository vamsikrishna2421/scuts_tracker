{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true }
    },
    "preview": {
      "distribution": "internal"
    },
    "testflight": {
      "distribution": "store",
      "autoIncrement": true,
      "ios": { "resourceClass": "m-medium" }
    },
    "apk": {
      "distribution": "internal",
      "android": { "buildType": "apk" }
    }
  },
  "submit": {
    "testflight": {
      "ios": {}
    }
  }
}
