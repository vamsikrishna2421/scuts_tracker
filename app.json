{
  "expo": {
    "name": "Scuts Tracker",
    "slug": "scuts-tracker",
    "scheme": "scutstracker",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F2F3F8",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/2f7538cf-778c-4121-80b4-314c2f41e79b",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scuts.tracker",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Scuts Tracker uses the microphone so you can dictate updates about salon owners.",
        "NSSpeechRecognitionUsageDescription": "Scuts Tracker turns your voice into private on-device text.",
        "NSPhotoLibraryUsageDescription": "Scuts Tracker does not access your photo library for any feature; iOS requires this notice because a bundled system component references the photo APIs."
      }
    },
    "android": {
      "package": "com.scuts.tracker",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#5C50DC",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#5C50DC",
          "image": "./assets/splash-icon.png",
          "imageWidth": 170
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Scuts Tracker uses the microphone so you can dictate updates about salon owners.",
          "speechRecognitionPermission": "Scuts Tracker turns your voice into private on-device text."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0",
            "buildSettings": {
              "ENABLE_USER_SCRIPT_SANDBOXING": "NO"
            }
          },
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2f7538cf-778c-4121-80b4-314c2f41e79b"
      }
    },
    "owner": "lekkala2421"
  }
}
